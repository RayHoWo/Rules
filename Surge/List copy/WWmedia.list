# NAME: Worldwide Media
# AUTHOR: RayHW
# DESCRIPTION: Curated worldwide and region-aware sports, music and streaming media routing rules (Optimized: Removed high-risk trackers)
# UPDATED: 2026-05-28
# SOURCE: blackmatrix7 ios_rule_script + official / actual service domains
# SOURCE-URL-DAZN: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/DAZN/DAZN.list
# SOURCE-URL-DEEZER: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Deezer/Deezer.list
# SOURCE-URL-TIDAL: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/TIDAL/TIDAL.list
# SOURCE-URL-SOUNDCLOUD: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/SoundCloud/SoundCloud.list
# FORMAT: Surge Rule Set

# === DAZN (Sports Streaming) ===
DOMAIN-SUFFIX,dazn.com
DOMAIN-SUFFIX,dazn-api.com
DOMAIN-SUFFIX,dazndn.com
DOMAIN-SUFFIX,indazn.com
DOMAIN-SUFFIX,indaznlab.com
DOMAIN-KEYWORD,voddazn
USER-AGENT,DAZN*

# === Deezer (Music) ===
DOMAIN-SUFFIX,deezer.com
DOMAIN-SUFFIX,dzcdn.net
DOMAIN-SUFFIX,deezer.page.link
USER-AGENT,Deezer*

# === TIDAL (Hi-Fi Music) ===
DOMAIN-SUFFIX,tidal.com
DOMAIN-SUFFIX,tidalhifi.com
DOMAIN-SUFFIX,wimpmusic.com
USER-AGENT,TIDAL*
USER-AGENT,TIDAL*dia

# === SoundCloud ===
DOMAIN-SUFFIX,soundcloud.com
DOMAIN-SUFFIX,sndcdn.com
DOMAIN-SUFFIX,soundcloud.app.goo.gl
DOMAIN-SUFFIX,p-cdn.us
USER-AGENT,SoundCloud*